{
  "$schema": "../schema/match.schema.json",
  "preset": "wave-survival",
  "description": "Wave survival match — escalating enemy waves, shop between waves, endless or fixed count",
  "winCondition": "survive_all_waves",
  "loseCondition": "player_hp_zero",
  "waves": {
    "count": 10,
    "endless": false,
    "baseEnemyCount": 5,
    "enemyCountMultiplier": 1.3,
    "baseEnemyHP": 50,
    "hpMultiplier": 1.2,
    "intermissionDuration": 15,
    "bossWaveInterval": 5
  },
  "scoring": {
    "killScore": 10,
    "waveBonus": 100,
    "timeBonus": true,
    "multiplierOnStreak": true,
    "streakThreshold": 5
  },
  "shop": {
    "enabled": true,
    "currency": "coins",
    "coinDropRate": 1.0,
    "shopDuration": 15
  },
  "ui": {
    "waveCounter": true,
    "enemyRemaining": true,
    "timerBar": false,
    "scoreDisplay": true
  },
  "restartBehavior": "return_to_menu"
}
