{
  "preset_name": "console",
  "version": "1.0",
  "target_platform": "console",
  "device_class": "ps5-xbox-sx",
  "fps_target": 60,
  "memory_budget_mb": 10240,
  "description": "PlayStation 5 / Xbox Series X. Cutting-edge visuals and performance via HDRP.",
  "quality_settings": {
    "pixelLightCount": 8,
    "shadowResolution": "VeryHigh",
    "shadowDistance": 300,
    "antiAliasing": 8,
    "vSyncCount": 1,
    "masterTextureLimit": 0,
    "anisotropicFiltering": "ForceEnable",
    "lodBias": 0.7,
    "softParticles": true,
    "realtimeReflectionProbes": true,
    "billboardsFaceCameraPosition": true
  },
  "render_pipeline_asset_overrides": {
    "URP": {
      "renderScale": 1.0,
      "shadowDistance": 300,
      "shadowResolution": "VeryHigh",
      "shadowCascadeCount": 4,
      "msaaSampleCount": 8,
      "maxVisibleLights": 32,
      "perObjectLimitAdditionalLights": 8,
      "supportsDynamicResolution": false,
      "screenSpaceShadows": true,
      "decalTech": "Clustered",
      "additionalLightsRenderingMode": "Forward",
      "mainLightRenderingMode": "Forward"
    },
    "HDRP": {
      "renderScale": 1.2,
      "shadowDistance": 300,
      "colorBufferFormat": "R16G16B16A16",
      "depthBufferFormat": "D32",
      "upsamplingFilter": "CatmullRom",
      "pathtracer": {
        "enabled": true,
        "maxBounces": 5
      },
      "rayTracing": {
        "enabled": true,
        "maxRaySteps": 128,
        "reflections": true,
        "pathTracing": true,
        "ambientOcclusion": true
      },
      "screenSpaceLighting": {
        "enabled": true,
        "reflections": true,
        "ambientOcclusion": true
      }
    }
  },
  "physics_settings": {
    "defaultSolverIterations": 16,
    "defaultSolverVelocityIterations": 4,
    "fixedDeltaTime": 0.0167,
    "autoSyncTransforms": true
  },
  "ui_settings": {
    "canvasScalabilityTarget": "StandardDPI",
    "dynamicPixelsPerPoint": true
  },
  "estimated_impact": {
    "fps_improvement": "5-15% vs. default (console baseline)",
    "memory_reduction": "5-10% (mainly texture optimization)",
    "draw_call_reduction": "5-10%"
  },
  "applied_via": "Craft_ModifyComponent + HDRP asset override (recommended over URP for console)"
}
