  "effects": [
    {
      "group": "Master",
      "effectType": "AudioMixerEffectController",
      "effectName": "Saturation",
      "enabled": true,
      "parameters": {
        "drive": 0.4,
        "tone": 0.6
      }
    },
    {
      "group": "Music",
      "effectType": "AudioMixerEffectController",
      "effectName": "Parametric EQ",
      "enabled": true,
      "parameters": {
        "centerFreq_1k": 1000,
        "gain_1k": 4,
        "centerFreq_4k": 4000,
        "gain_4k": 3,
        "centerFreq_100hz": 100,
        "gain_100hz": 0
      }
    },
    {
      "group": "Music",
      "effectType": "AudioMixerEffectController",
      "effectName": "Compressor",
      "enabled": true,
      "parameters": {
        "threshold": -12,
        "ratio": 4,
        "attackTime": 0.01,
        "releaseTime": 0.4,
        "makeupGain": 0
      }
    },
    {
      "group": "SFX",
      "effectType": "AudioMixerEffectController",
      "effectName": "Saturation",
      "enabled": true,
      "parameters": {
        "drive": 0.5,
        "tone": 0.5
      }
    },
    {
      "group": "SFX",
      "effectType": "AudioMixerEffectController",
      "effectName": "HighPass",
      "enabled": true,
      "parameters": {
        "cutoffFrequency": 50,
        "resonanceQ": 1
      }
    },
    {
      "group": "UI",
      "effectType": "AudioMixerEffectController",
      "effectName": "Compressor",
      "enabled": true,
      "parameters": {
        "threshold": -16,
        "ratio": 2,
        "attackTime": 0.005,
        "releaseTime": 0.15,
        "makeupGain": 0
      }
