{
  "preset_name": "ThirdPerson",
  "version": "1.0",
  "target": "CinemachineCamera",
  "properties": {
    "m_Lens": {
      "FieldOfView": 60,
      "NearClipPlane": 0.1,
      "FarClipPlane": 5000,
      "dutch": 0
    },
    "m_Body": {
      "type": "ThirdPersonFollow",
      "properties": {
        "m_FollowAboveGround": true,
        "m_FollowHeight": 1.5,
        "m_FollowDistance": 3,
        "m_CameraCollisionQueryPadding": 0.1,
        "m_Damping": 0.3,
        "m_ShoulderOffset": [1, 1.5, 0],
        "m_VerticalShoulderOffset": 0.4,
        "m_CameraSide": 1
      }
    },
    "m_Aim": {
      "type": "HardLookAt",
      "properties": {
        "m_TrackedObjectOffset": [0, 0.6, 0],
        "m_LookaheadTime": 0,
        "m_LookaheadSmoothing": 10,
        "m_LookaheadZoomOutMaxDistance": 0,
        "m_LookaheadZoomOutMinDistance": 0,
        "m_HorizontalDamping": 0,
        "m_VerticalDamping": 0,
        "m_DeadZoneWidth": 0,
        "m_DeadZoneHeight": 0,
        "m_SoftZoneWidth": 0.5,
        "m_SoftZoneHeight": 0.5,
        "m_BiasX": 0,
        "m_BiasY": 0,
        "m_CenterOnActivate": true
      }
    },
    "m_Noise": {
      "enabled": false,
      "Frequency": 1,
      "Amplitude": 0,
      "FilterSize": 1
    },
    "m_Damping": 0.3,
    "m_Priority": 10
  }
}
