{
  "preset_name": "Orbit",
  "version": "1.0",
  "target": "CinemachineCamera",
  "properties": {
    "m_Lens": {
      "FieldOfView": 50,
      "NearClipPlane": 0.1,
      "FarClipPlane": 5000,
      "dutch": 0
    },
    "m_Body": {
      "type": "OrbitalTransposer",
      "properties": {
        "m_FollowOffset": [5, 2, 0],
        "m_XAxis": {
          "Value": 0,
          "Range": [0, 360],
          "Wrap": true,
          "ModifyValue": true
        },
        "m_YAxis": {
          "Value": 0.4,
          "Range": [0, 1],
          "Wrap": false,
          "ModifyValue": true
        },
        "m_Radius": 5,
        "m_HeightOffset": 2,
        "m_MinimumDistance": 1,
        "m_MaximumDistance": 50,
        "m_Damping": 0.3
      }
    },
    "m_Aim": {
      "type": "Composer",
      "properties": {
        "m_TrackedObjectOffset": [0, 0.6, 0],
        "m_LookaheadTime": 0,
        "m_LookaheadSmoothing": 10,
        "m_LookaheadZoomOutMaxDistance": 0,
        "m_LookaheadZoomOutMinDistance": 0,
        "m_HorizontalDamping": 0.3,
        "m_VerticalDamping": 0.3,
        "m_ScreenX": 0.5,
        "m_ScreenY": 0.5,
        "m_DeadZoneWidth": 0,
        "m_DeadZoneHeight": 0,
        "m_SoftZoneWidth": 1,
        "m_SoftZoneHeight": 1,
        "m_BiasX": 0,
        "m_BiasY": 0,
        "m_CenterOnActivate": true
      }
    },
    "m_Noise": {
      "enabled": false,
      "Frequency": 1,
      "Amplitude": 0,
      "FilterSize": 1
    },
    "m_Damping": 0.3,
    "m_Priority": 10
  }
}
