{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "match.schema.json",
  "title": "Match Preset",
  "description": "Schema for ccplugin-unity-craft match system presets",
  "type": "object",
  "required": ["preset", "description", "winCondition", "loseCondition"],
  "properties": {
    "preset": { "type": "string" },
    "description": { "type": "string" },
    "winCondition": { "type": "string" },
    "loseCondition": { "type": "string" },
    "scoring": {
      "type": "object",
      "additionalProperties": true
    },
    "ui": {
      "type": "object",
      "additionalProperties": { "type": ["boolean", "string"] }
    },
    "restartBehavior": {
      "type": "string",
      "enum": ["return_to_menu", "return_to_lobby", "same_race", "retry_level", "next_level"]
    }
  },
  "additionalProperties": true
}
