{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Level Preset",
  "description": "Schema for Unity scene / level layout presets expressed as CRAFT operations",
  "type": "object",
  "additionalProperties": false,
  "required": ["preset_name", "version", "target", "operations"],
  "properties": {
    "preset_name": { "type": "string" },
    "version": { "type": "string" },
    "target": { "type": "string", "enum": ["Scene"] },
    "requires_packages": {
      "type": "array",
      "items": { "type": "string" }
    },
    "origin_offset": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3
    },
    "_note": { "type": "string" },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["CreateGameObject", "ModifyComponent", "DeleteGameObject", "SetParent", "AddComponent"]
          },
          "target": { "type": "string" },
          "parameters": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "primitiveType": {
                "type": "string",
                "enum": ["Sphere", "Capsule", "Cylinder", "Cube", "Plane", "Quad"]
              },
              "position": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 3,
                "maxItems": 3
              },
              "rotation": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 3,
                "maxItems": 3
              },
              "scale": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 3,
                "maxItems": 3
              },
              "components": {
                "type": "array",
                "items": { "type": "string" }
              },
              "tags": {
                "type": "array",
                "items": { "type": "string" }
              },
              "componentType": { "type": "string" },
              "values": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      }
    }
  }
}
