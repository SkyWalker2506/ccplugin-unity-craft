{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quality Preset",
  "description": "Schema for Unity quality settings presets (QualitySettings + render pipeline overrides)",
  "type": "object",
  "additionalProperties": false,
  "required": ["preset_name", "version", "target_platform", "quality_settings"],
  "properties": {
    "preset_name": { "type": "string" },
    "version": { "type": "string" },
    "target_platform": { "type": "string" },
    "device_class": { "type": "string" },
    "fps_target": { "type": "number" },
    "memory_budget_mb": { "type": "number" },
    "description": { "type": "string" },
    "applied_via": { "type": "string" },
    "quality_settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pixelLightCount": { "type": "integer" },
        "shadowResolution": { "type": "string", "enum": ["Low", "Medium", "High", "VeryHigh"] },
        "shadowDistance": { "type": "number" },
        "antiAliasing": { "type": "integer", "enum": [0, 2, 4, 8] },
        "vSyncCount": { "type": "integer", "enum": [0, 1, 2] },
        "masterTextureLimit": { "type": "integer" },
        "anisotropicFiltering": { "type": "string", "enum": ["Disable", "Enable", "ForceEnable"] },
        "lodBias": { "type": "number" },
        "softParticles": { "type": "boolean" },
        "realtimeReflectionProbes": { "type": "boolean" },
        "billboardsFaceCameraPosition": { "type": "boolean" }
      }
    },
    "render_pipeline_asset_overrides": {
      "type": "object",
      "additionalProperties": true
    },
    "physics_settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultSolverIterations": { "type": "integer" },
        "defaultSolverVelocityIterations": { "type": "integer" },
        "fixedDeltaTime": { "type": "number" },
        "autoSyncTransforms": { "type": "boolean" }
      }
    },
    "ui_settings": {
      "type": "object",
      "additionalProperties": true
    },
    "estimated_impact": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
